# Copy to .env or .env.local and fill in your values.
# No API token needed; CivicClerk API is public.

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Authentication (Auth.js / NextAuth.js v5)
# Generate with: openssl rand -base64 32
# AUTH_SECRET is the canonical name for v5; NEXTAUTH_SECRET also works
AUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Email (Resend - for magic link login)
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx
# Optional: Custom from address (requires verified domain in Resend)
# EMAIL_FROM=City of Santa Fe Agendas & Minutes <noreply@yourdomain.com>

# Cron (for daily digest emails)
# Set a secret and call GET /api/cron/notifications with Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-cron-secret-here

# Optional: AI features (OpenRouter)
# Powers committee summaries, agenda summaries, document chat, and embeddings
# Omit to disable all AI features
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxx
